{
  "name": "cachezero",
  "version": "0.1.6",
  "description": "AI-powered second brain — bookmark, compile, query",
  "type": "module",
  "bin": {
    "cachezero": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "extension"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@hono/node-server": "^1.13.0",
    "@lancedb/lancedb": "^0.15.0",
    "apache-arrow": "^18.1.0",
    "commander": "^13.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cachezero/shared": "workspace:*",
    "@cachezero/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "5.9.2"
  },
  "keywords": ["knowledge-base", "second-brain", "bookmarks", "obsidian", "ai"],
  "license": "MIT"
}
